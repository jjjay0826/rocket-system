/*
 * lora.c - SX1268S433N0S1 LoRa driver
 *
 * 硬體接線（PCB 確認）：
 *   SCK  = PB12 (SPI3, AF7, 與 BMP585/IMU 共用)
 *   MISO = PB4  (SPI3, AF6)
 *   MOSI = PB5  (SPI3, AF6)
 *   NSS  = PB10 (GPIO_Output, CS2)
 *   RST  = 接 GND（無硬體 reset 能力，軟體略過）
 *   BUSY = 接 GND（永遠 LOW = ready，用延遲代替等待）
 *   DIO1 = NC（不使用中斷，用延遲等待 TX 完成）
 *
 * 設定：433 MHz，LoRa，SF7，BW125kHz，CR4/5，14dBm
 */

#include "lora.h"
#include "spi.h"
#include "main.h"
#include <string.h>

/* ── CS 腳（PB10）── */
#define LORA_CS_PORT  GPIOB
#define LORA_CS_PIN   GPIO_PIN_10

#define LORA_CS_LOW()   HAL_GPIO_WritePin(LORA_CS_PORT, LORA_CS_PIN, GPIO_PIN_RESET)
#define LORA_CS_HIGH()  HAL_GPIO_WritePin(LORA_CS_PORT, LORA_CS_PIN, GPIO_PIN_SET)

/* ── SPI handle（與 BMP585/IMU 共用 SPI3）── */
extern SPI_HandleTypeDef hspi3;

/* ── SX1268 命令碼 ── */
#define CMD_SET_STANDBY        0x80
#define CMD_SET_PACKET_TYPE    0x8A
#define CMD_SET_RF_FREQ        0x86
#define CMD_SET_PA_CONFIG      0x95
#define CMD_SET_TX_PARAMS      0x8E
#define CMD_SET_MODULATION     0x8B
#define CMD_SET_PACKET_PARAMS  0x8C
#define CMD_SET_BUFFER_BASE    0x8F
#define CMD_WRITE_BUFFER       0x0E
#define CMD_SET_TX             0x83
#define CMD_GET_STATUS         0xC0
#define CMD_SET_DIO_IRQ        0x08
#define CMD_CLEAR_IRQ          0x02
#define CMD_CALIBRATE_IMAGE    0x98
#define CMD_SET_RX             0x82
#define CMD_GET_IRQ_STATUS     0x12
#define CMD_GET_RX_BUF_STATUS  0x13
#define CMD_READ_BUFFER        0x1E

/* IRQ 旗標位元 */
#define IRQ_TX_DONE   0x0001U  /* bit 0 */
#define IRQ_RX_DONE   0x0002U  /* bit 1 */
#define IRQ_CRC_ERR   0x0040U  /* bit 6 */

/* ── 非阻塞 TX 狀態機內部狀態 ── */
#define LORA_TX_TIMEOUT_MS  800U   /* SF7 BW125 255B ≈ 250ms，留 800ms 安全裕度
                                    * 注意：PollTx 須在主迴圈每次呼叫才有效，
                                    * 若只在 500ms block 呼叫，500ms > 400ms 會誤超時 */
typedef enum { LORA_TX_ST_IDLE, LORA_TX_ST_BUSY } LoRaTxSt_t;
static volatile LoRaTxSt_t lora_tx_st    = LORA_TX_ST_IDLE;
static volatile uint32_t   lora_tx_start = 0;

/* ──────────────────────────────────────────
 * 底層 SPI 輔助函式
 * ────────────────────────────────────────── */

/* 送 1 byte，忽略回傳 */
static void spi_write_byte(uint8_t b)
{
    HAL_SPI_Transmit(&hspi3, &b, 1, 10);
}

/* 送多 byte */
static void spi_write_buf(const uint8_t *buf, uint16_t len)
{
    HAL_SPI_Transmit(&hspi3, (uint8_t*)buf, len, 50);
}

/* ──────────────────────────────────────────
 * SX1268 命令送出（無回傳資料）
 * ────────────────────────────────────────── */
static void sx_cmd(uint8_t cmd, const uint8_t *params, uint8_t nparams)
{
    /* BUSY = GND，永遠 ready，不需等待 */
    LORA_CS_LOW();
    spi_write_byte(cmd);
    if (params && nparams > 0) {
        spi_write_buf(params, nparams);
    }
    LORA_CS_HIGH();
    HAL_Delay(1); /* 給 SX1268 處理命令的最小時間 */
}

/* ──────────────────────────────────────────
 * 寫入 TX buffer
 * ────────────────────────────────────────── */
static void sx_write_buffer(uint8_t offset, const uint8_t *data, uint8_t len)
{
    LORA_CS_LOW();
    spi_write_byte(CMD_WRITE_BUFFER);
    spi_write_byte(offset);
    spi_write_buf(data, len);
    LORA_CS_HIGH();
    HAL_Delay(1);
}

/* ──────────────────────────────────────────
 * 讀取 IRQ 狀態暫存器（2 byte）
 * ────────────────────────────────────────── */
static uint16_t sx_get_irq(void)
{
    uint8_t cmd = CMD_GET_IRQ_STATUS;
    uint8_t buf[3] = {0, 0, 0}; /* status + IRQ_MSB + IRQ_LSB */
    LORA_CS_LOW();
    HAL_SPI_Transmit(&hspi3, &cmd, 1, 10);
    HAL_SPI_Receive(&hspi3, buf, 3, 10);
    LORA_CS_HIGH();
    return ((uint16_t)buf[1] << 8) | buf[2];
}

/* ──────────────────────────────────────────
 * 取得 RX 緩衝區狀態（payload 長度 + 起始位址）
 * ────────────────────────────────────────── */
static void sx_get_rx_buf_status(uint8_t *plen, uint8_t *pstart)
{
    uint8_t cmd = CMD_GET_RX_BUF_STATUS;
    uint8_t buf[3] = {0, 0, 0}; /* status + payloadLen + startPtr */
    LORA_CS_LOW();
    HAL_SPI_Transmit(&hspi3, &cmd, 1, 10);
    HAL_SPI_Receive(&hspi3, buf, 3, 10);
    LORA_CS_HIGH();
    *plen   = buf[1];
    *pstart = buf[2];
}

/* ──────────────────────────────────────────
 * 從 RX buffer 讀出資料
 * ────────────────────────────────────────── */
static void sx_read_buffer(uint8_t offset, uint8_t *data, uint8_t len)
{
    uint8_t hdr[2] = {CMD_READ_BUFFER, offset};
    uint8_t status = 0;
    LORA_CS_LOW();
    HAL_SPI_Transmit(&hspi3, hdr, 2, 10);
    HAL_SPI_Receive(&hspi3, &status, 1, 10); /* NOP status byte，捨棄 */
    HAL_SPI_Receive(&hspi3, data, len, 50);
    LORA_CS_HIGH();
    HAL_Delay(1);
}

/* ──────────────────────────────────────────
 * 433 MHz PLL 字
 * fRF = 433,000,000 Hz
 * PLL = fRF * 2^25 / 32,000,000 = 0x1B100000
 * ────────────────────────────────────────── */
#define FREQ_433_BYTE0  0x1B
#define FREQ_433_BYTE1  0x10
#define FREQ_433_BYTE2  0x00
#define FREQ_433_BYTE3  0x00

/* ──────────────────────────────────────────
 * LoRa_Init
 * 回傳 0=成功
 * ────────────────────────────────────────── */
int LoRa_Init(void)
{
    /* CS idle HIGH */
    LORA_CS_HIGH();

    /* 電源穩定等待（RST 接 GND，無法硬 reset，靠 POR）*/
    HAL_Delay(20);

    /* 1. Standby RC 模式 */
    {
        uint8_t p = 0x00; /* STDBY_RC */
        sx_cmd(CMD_SET_STANDBY, &p, 1);
    }

    /* 2. 封包類型 = LoRa */
    {
        uint8_t p = 0x01;
        sx_cmd(CMD_SET_PACKET_TYPE, &p, 1);
    }

    /* 3. 射頻頻率 = 433 MHz */
    {
        uint8_t p[4] = { FREQ_433_BYTE0, FREQ_433_BYTE1,
                         FREQ_433_BYTE2, FREQ_433_BYTE3 };
        sx_cmd(CMD_SET_RF_FREQ, p, 4);
    }

    /* 4. Image calibration（433 MHz band = 0x6B, 0x6F）*/
    {
        uint8_t p[2] = { 0x6B, 0x6F };
        sx_cmd(CMD_CALIBRATE_IMAGE, p, 2);
        HAL_Delay(5);
    }

    /* 5. PA 設定（SX1268，最大 22dBm 晶片，設 14dBm 安全值）
     *   paDutyCycle=0x02, hpMax=0x02, deviceSel=0x00(SX1268), paLut=0x01 */
    {
        uint8_t p[4] = { 0x02, 0x02, 0x00, 0x01 };
        sx_cmd(CMD_SET_PA_CONFIG, p, 4);
    }

    /* 6. TX 功率與斜率
     *   power=0x0E(+14dBm), rampTime=0x04(200us) */
    {
        uint8_t p[2] = { 0x0E, 0x04 };
        sx_cmd(CMD_SET_TX_PARAMS, p, 2);
    }

    /* 7. 調變參數（LoRa）
     *   SF=7, BW=125kHz(0x04), CR=4/5(0x01), lowDataRateOptimize=0x00 */
    {
        uint8_t p[4] = { 0x07, 0x04, 0x01, 0x00 };
        sx_cmd(CMD_SET_MODULATION, p, 4);
    }

    /* 8. 封包參數
     *   preambleLen=8, headerType=Explicit(0x00),
     *   payloadLen=0xFF(最大，TX時會指定), CRC=ON(0x01), invertIQ=OFF(0x00) */
    {
        uint8_t p[6] = { 0x00, 0x08, 0x00, 0xFF, 0x01, 0x00 };
        sx_cmd(CMD_SET_PACKET_PARAMS, p, 6);
    }

    /* 9. 設定 TX/RX buffer 基址（TX=0x00, RX=0x00）*/
    {
        uint8_t p[2] = { 0x00, 0x00 };
        sx_cmd(CMD_SET_BUFFER_BASE, p, 2);
    }

    /* 10. 關閉所有 DIO IRQ（DIO1=NC）*/
    {
        uint8_t p[4] = { 0x00, 0x00, 0x00, 0x00 };
        sx_cmd(CMD_SET_DIO_IRQ, p, 4);
    }

    return 0;
}

/* ──────────────────────────────────────────
 * LoRa_Send
 * data: 要傳送的資料，len: 長度（≤255）
 * 回傳 0=成功
 * ────────────────────────────────────────── */
int LoRa_Send(const uint8_t *data, uint8_t len)
{
    if (!data || len == 0) return -1;
    if (len > 255) len = 255;

    /* 1. 回到 Standby */
    {
        uint8_t p = 0x00;
        sx_cmd(CMD_SET_STANDBY, &p, 1);
    }

    /* 2. 更新封包長度 */
    {
        uint8_t p[6] = { 0x00, 0x08, 0x00, len, 0x01, 0x00 };
        sx_cmd(CMD_SET_PACKET_PARAMS, p, 6);
    }

    /* 3. 清除 IRQ 旗標 */
    {
        uint8_t p[2] = { 0xFF, 0xFF };
        sx_cmd(CMD_CLEAR_IRQ, p, 2);
    }

    /* 4. 寫入 TX buffer（從 offset 0 開始）*/
    sx_write_buffer(0x00, data, len);

    /* 5. 開始傳送（timeout=0 = 直到 TX done 才停）*/
    {
        uint8_t p[3] = { 0x00, 0x00, 0x00 };
        sx_cmd(CMD_SET_TX, p, 3);
    }

    /* 6. 等待 TX 完成
     * BUSY/DIO1 均未接，用保守延遲：
     * SF7 BW125 payload=255 bytes：約 ~250ms 最壞情況
     * 一般短封包（<64B）約 50~100ms */
    uint32_t wait_ms = 20 + (uint32_t)len * 2; /* 保守估算 */
    if (wait_ms < 50) wait_ms = 50;
    if (wait_ms > 300) wait_ms = 300;
    HAL_Delay(wait_ms);

    /* 7. 回到 Standby（省電）*/
    {
        uint8_t p = 0x00;
        sx_cmd(CMD_SET_STANDBY, &p, 1);
    }

    return 0;
}

/* ──────────────────────────────────────────
 * LoRa_SendStr - 傳送字串
 * ────────────────────────────────────────── */
int LoRa_SendStr(const char *str)
{
    if (!str) return -1;
    uint8_t len = (uint8_t)strlen(str);
    return LoRa_Send((const uint8_t*)str, len);
}

/* ──────────────────────────────────────────
 * LoRa_StartRx
 * 進入連續接收模式，呼叫一次即可持續監聽
 * 回傳 0=成功
 * ────────────────────────────────────────── */
int LoRa_StartRx(void)
{
    /* 1. 回到 Standby */
    {
        uint8_t p = 0x00;
        sx_cmd(CMD_SET_STANDBY, &p, 1);
    }

    /* 2. 清除所有 IRQ 旗標 */
    {
        uint8_t p[2] = {0xFF, 0xFF};
        sx_cmd(CMD_CLEAR_IRQ, p, 2);
    }

    /* 3. 啟用 IRQ mask：RxDone(bit1)+CrcErr(bit6)=0x0042
     *    SetDioIrqParams: IrqMask(2) + DIO1Mask(2) + DIO2Mask(2) + DIO3Mask(2)
     *    DIO1=NC，不路由到任何 DIO，只啟用 flag 供 polling 用 */
    {
        uint8_t p[8] = {0x00, 0x42, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00};
        sx_cmd(CMD_SET_DIO_IRQ, p, 8);
    }

    /* 4. 進入連續 RX 模式（timeout=0xFFFFFF=持續接收）*/
    {
        uint8_t p[3] = {0xFF, 0xFF, 0xFF};
        sx_cmd(CMD_SET_RX, p, 3);
    }

    return 0;
}

/* ──────────────────────────────────────────
 * LoRa_Receive
 * 輪詢接收（非阻塞），建議在 main loop 每 10ms 呼叫一次
 *   buf     : 接收緩衝區
 *   max_len : 緩衝區最大長度
 *   回傳值  :  >0 = 收到的 byte 數
 *              0  = 尚未收到
 *             -1  = CRC 錯誤（封包丟棄）
 * ────────────────────────────────────────── */
int LoRa_Receive(uint8_t *buf, uint8_t max_len)
{
    if (!buf || max_len == 0) return 0;

    uint16_t irq = sx_get_irq();

    /* CRC 錯誤 */
    if (irq & IRQ_CRC_ERR) {
        uint8_t clr[2] = {0xFF, 0xFF};
        sx_cmd(CMD_CLEAR_IRQ, clr, 2);
        return -1;
    }

    /* 收到完整封包 */
    if (irq & IRQ_RX_DONE) {
        /* 清除旗標 */
        uint8_t clr[2] = {0xFF, 0xFF};
        sx_cmd(CMD_CLEAR_IRQ, clr, 2);

        /* 取得 payload 長度與起始位址 */
        uint8_t plen = 0, pstart = 0;
        sx_get_rx_buf_status(&plen, &pstart);

        if (plen == 0) return 0;
        if (plen > max_len) plen = max_len;

        /* 從 buffer 讀出資料 */
        sx_read_buffer(pstart, buf, plen);

        return (int)plen;
    }

    return 0; /* 尚未收到 */
}

/* ═══════════════════════════════════════════════════════════════
 * LoRa_SendAsync
 * 寫入 FIFO 並啟動 TX，立即返回（不等射頻完成）。
 * BUSY=GND（永遠 ready）→ 不需等待 BUSY pin，靠 HAL_Delay(1) 補位。
 * ═══════════════════════════════════════════════════════════════ */
int LoRa_SendAsync(const uint8_t *data, uint8_t len)
{
    if (lora_tx_st != LORA_TX_ST_IDLE) return -1;
    if (!data || len == 0)             return -2;
    if (len > 255) len = 255;

    /* Standby → 更新封包長度 → 清除 IRQ → 寫入 FIFO → 啟動 TX */
    { uint8_t p = 0x00;
      sx_cmd(CMD_SET_STANDBY, &p, 1); }
    { uint8_t p[6] = { 0x00, 0x08, 0x00, len, 0x01, 0x00 };
      sx_cmd(CMD_SET_PACKET_PARAMS, p, 6); }
    { uint8_t p[2] = { 0xFF, 0xFF };
      sx_cmd(CMD_CLEAR_IRQ, p, 2); }
    sx_write_buffer(0x00, data, len);
    { uint8_t p[3] = { 0x00, 0x00, 0x00 };   /* timeout=0：TX 完成即自動停止 */
      sx_cmd(CMD_SET_TX, p, 3); }

    lora_tx_st    = LORA_TX_ST_BUSY;
    lora_tx_start = HAL_GetTick();
    return 0;   /* TX 已啟動，射頻仍在發送 */
}

/* ═══════════════════════════════════════════════════════════════
 * LoRa_PollTx
 * 主迴圈每次呼叫，輪詢 SX1268 GetIrqStatus 的 TxDone bit（bit 0）。
 *   1  = 完成（TxDone 偵測到）或無待傳任務
 *   0  = 仍在傳送中
 *  -1  = 超時，已強制 Standby
 * ═══════════════════════════════════════════════════════════════ */
int LoRa_PollTx(void)
{
    if (lora_tx_st == LORA_TX_ST_IDLE) return 1;   /* 無待傳任務 */

    /* 輪詢 TxDone IRQ flag（不阻塞，單次 SPI 讀取）*/
    if (sx_get_irq() & IRQ_TX_DONE) {
        uint8_t p[2] = { 0xFF, 0xFF };
        sx_cmd(CMD_CLEAR_IRQ, p, 2);        /* 清除 IRQ 旗標 */
        uint8_t sb = 0x00;
        sx_cmd(CMD_SET_STANDBY, &sb, 1);    /* 回到 Standby 省電 */
        lora_tx_st = LORA_TX_ST_IDLE;
        return 1;   /* TX 成功完成 */
    }

    /* 超時保護：防止硬體死鎖無限等待 */
    if (HAL_GetTick() - lora_tx_start > LORA_TX_TIMEOUT_MS) {
        uint8_t sb = 0x00;
        sx_cmd(CMD_SET_STANDBY, &sb, 1);
        lora_tx_st = LORA_TX_ST_IDLE;
        return -1;  /* 超時，視為失敗 */
    }

    return 0;   /* 仍在傳送，下次再查 */
}

/* ═══════════════════════════════════════════════════════════════ */
uint8_t LoRa_IsBusy(void) { return (uint8_t)(lora_tx_st != LORA_TX_ST_IDLE); }
